{
  "manifest_version": 3,
  "name": "Real-time",
  "description": "Shows real remaining time based on the current video playback speed.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Real-time"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://vimeo.com/*",
        "https://player.vimeo.com/*"
      ],
      "js": [
        "content-utils.js",
        "content-panel.js",
        "adapters/youtube.js",
        "adapters/vimeo.js",
        "adapters/generic.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
