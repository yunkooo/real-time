{
  "manifest_version": 3,
  "name": "Real-time",
  "description": "Shows real remaining time based on the current YouTube playback speed.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Real-time"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
